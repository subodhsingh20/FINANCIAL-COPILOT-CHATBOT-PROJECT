PORT=5000
CLOUDANT_URL=https://username:password@your-account.cloudantnosqldb.appdomain.cloud
CLOUDANT_USERS_DB=users
CLOUDANT_CONVERSATIONS_DB=conversations
CLOUDANT_PORTFOLIOS_DB=portfolios
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain
FRONTEND_BASE_URL=https://your-frontend-domain
